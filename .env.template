# Azure Voice Live (Azure AI Speech / OpenAI Realtime)
AZURE_VOICELIVE_ENDPOINT=
# API key — leave blank to use DefaultAzureCredential instead
# (locally: az login; Azure-hosted: managed identity)
AZURE_VOICELIVE_API_KEY=

# Azure Communication Services — choose one authentication method:
#   Option A: Connection string (access key)
AZURE_COMMUNICATION_CONNECTION_STRING=
#   Option B: Endpoint URL — use DefaultAzureCredential (az login locally, managed identity in Azure)
#   Requires "Communication Services Owner" or "Contributor" role on the ACS resource.
AZURE_COMMUNICATION_ENDPOINT=

# Teams Meeting
TEAMS_MEETING_LINK=

# Voice Live model and voice (optional - defaults shown)
VOICELIVE_MODEL=gpt-4o-realtime
VOICELIVE_VOICE=en-US-AvaMultilingualNeural
